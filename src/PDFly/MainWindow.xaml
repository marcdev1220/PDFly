<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PDFly.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:PDFly.Converters"
    xmlns:models="using:PDFly.Models"
    Title="PDFly">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="Root">
        <Grid.Resources>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:StatusToGlyphConverter   x:Key="StatusToGlyph"/>
            <conv:StatusToBrushConverter   x:Key="StatusToBrush"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar"
                  Grid.Row="0"
                  Title="PDFly"
                  Subtitle="Convert between Word and PDF">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="pdfly.ico"/>
            </TitleBar.IconSource>
        </TitleBar>

        <Grid x:Name="ContentRoot"
              Grid.Row="1"
              Background="Transparent"
              AllowDrop="True"
              DragOver="OnDragOver"
              DragEnter="OnDragOver"
              DragLeave="OnDragLeave"
              Drop="OnDrop">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Options card -->
            <Border Grid.Row="0"
                    Margin="22,16,22,10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,12">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="If the output file already exists:"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ComboBox Width="170"
                                  ItemsSource="{Binding PolicyChoices}"
                                  SelectedItem="{Binding SelectedPolicy, Mode=TwoWay}"
                                  ToolTipService.ToolTip="What to do when a file with the same name is already next to the source document."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="22">
                        <CheckBox Content="Include files in subfolders"
                                  IsChecked="{Binding IncludeSubfolders, Mode=TwoWay}"
                                  ToolTipService.ToolTip="When you drop or pick a folder, also convert documents in its subfolders."/>
                        <CheckBox Content="Open the folder when finished"
                                  IsChecked="{Binding OpenFolderWhenDone, Mode=TwoWay}"
                                  ToolTipService.ToolTip="Pop open the output folder once a batch finishes."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Drop zone -->
            <Grid Grid.Row="1" Margin="22,0,22,10">
                <Rectangle x:Name="DropZoneOutline"
                           RadiusX="10" RadiusY="10"
                           StrokeDashArray="5,3"
                           StrokeDashCap="Round"
                           StrokeThickness="1.3"
                           Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                           Fill="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
                <Grid Margin="14,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0"
                              Glyph="&#xE7C3;"
                              FontSize="22"
                              VerticalAlignment="Center"
                              Margin="2,0,14,0"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="Drop Word or PDF files (or folders) here"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Content="Add files…"   Command="{Binding AddFilesCommand}"/>
                        <Button Content="Add folder…"  Command="{Binding AddFolderCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- File list -->
            <Grid Grid.Row="2" Margin="14,0,14,6">
                <ListView x:Name="FilesList"
                          ItemsSource="{Binding Items}"
                          SelectionMode="None"
                          IsItemClickEnabled="False">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding"                 Value="10,2"/>
                            <Setter Property="MinHeight"               Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ConversionItem">
                            <Grid Margin="2,7" DoubleTapped="OnRowDoubleClick">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Open output"    Tag="{x:Bind}" Click="OnOpenItem"/>
                                        <MenuFlyoutItem Text="Show in folder" Tag="{x:Bind}" Click="OnRevealItem"/>
                                        <MenuFlyoutItem Text="Convert again"  Tag="{x:Bind}" Click="OnRequeueItem"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="Remove from list" Tag="{x:Bind}" Click="OnRemoveItem"/>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- {Binding} (runtime) instead of x:Bind here — the compiler-emitted
                                     x:Bind converter lookup needs a FrameworkElement root, which a WinUI
                                     Window isn't. Runtime binding walks resources without that constraint. -->
                                <FontIcon Grid.Column="0"
                                          Width="22"
                                          FontSize="16"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"
                                          Glyph="{Binding Status, Converter={StaticResource StatusToGlyph}}"
                                          Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                    <TextBlock Text="{x:Bind FileName}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock Text="No documents yet — drop Word or PDF files above to convert them."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="320"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsHitTestVisible="False"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>

            <!-- Bottom bar -->
            <Grid Grid.Row="3" Margin="22,8,22,16" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <HyperlinkButton Grid.Column="0"
                                 NavigateUri="https://ko-fi.com/marcdev"
                                 Padding="6,4"
                                 VerticalAlignment="Center"
                                 ToolTipService.ToolTip="Support PDFly on Ko-fi (opens in your browser)">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#x2665;" Foreground="#FF5E5B" VerticalAlignment="Center"/>
                        <TextBlock Text="Support on Ko-fi" VerticalAlignment="Center"/>
                    </StackPanel>
                </HyperlinkButton>
                <TextBlock Grid.Column="1"
                           Text="{Binding SummaryText, Mode=OneWay}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Content="Open folder"
                            Command="{Binding OpenOutputCommand}"
                            ToolTipService.ToolTip="Open the folder of the last converted file."/>
                    <Button Content="Clear"
                            Command="{Binding ClearCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
